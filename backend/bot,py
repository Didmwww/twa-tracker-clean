import asyncio
import os
from aiohttp import web
from aiogram import Bot, Dispatcher, types
from aiogram.filters import CommandStart
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton, WebAppInfo
from supabase import create_client, Client
from apscheduler.schedulers.asyncio import AsyncIOScheduler

BOT_TOKEN = os.getenv("BOT_TOKEN")
SUPABASE_URL = os.getenv("SUPABASE_URL")
SUPABASE_KEY = os.getenv("SUPABASE_KEY")
WEBAPP_URL = os.getenv("WEBAPP_URL") 

bot = Bot(token=BOT_TOKEN)
dp = Dispatcher()
supabase: Client = create_client(SUPABASE_URL, SUPABASE_KEY)
scheduler = AsyncIOScheduler()

@dp.message(CommandStart())
async def cmd_start(message: types.Message):
    user_data = {"telegram_id": message.from_user.id, "username": message.from_user.username}
    supabase.table("users").upsert(user_data).execute()

    markup = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Открыть Трекер 🏋️‍♂️", web_app=WebAppInfo(url=WEBAPP_URL))]
    ])
    await message.answer("Привет! Твой трекер тренировок и добавок готов.", reply_markup=markup)

async def send_reminder(text: str, user_id: int):
    try:
        await bot.send_message(chat_id=user_id, text=text)
    except Exception as e:
        print(f"Ошибка отправки: {e}")

# Заглушка для Render, чтобы он не убил процесс
async def health_check(request):
    return web.Response(text="Bot is running smoothly!")

async def main():
    # Запускаем микро-сервер для Render
    app = web.Application()
    app.router.add_get('/', health_check)
    runner = web.AppRunner(app)
    await runner.setup()
    port = int(os.environ.get("PORT", 8080))
    site = web.TCPSite(runner, '0.0.0.0', port)
    await site.start()

    # Включаем планировщик
    scheduler.start()
    
    print("Бот запущен и готов к работе!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())